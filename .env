# Server port (hosting platforms like Render/Railway set this automatically)
PORT=3000

# Timezone used for scheduling the two daily reminders
TZ_NAME=Asia/Kolkata

# Cron schedules (minute hour * * *) — defaults: 8:00 AM and 6:30 PM
MORNING_CRON=0 8 * * *
EVENING_CRON=30 18 * * *
